  "scripts": {
    "start": "bare index.js",
    "start:peer2": "bare index.js <TOPIC_HEX>",
    "ui": "electron electron/main.cjs --wallet-dir peer1-wallet",
    "ui:peer1": "electron electron/main.cjs --wallet-dir peer1-wallet --topic 191793e539695e202a4e962efee1e8fd9e09b1acddb851ec247eaf55cbb2e425",
    "ui:peer2": "electron electron/main.cjs --wallet-dir peer2-wallet --topic 191793e539695e202a4e962efee1e8fd9e09b1acddb851ec247eaf55cbb2e425",
    "test": "bare test.js && bare test-compute-escrow.js && bare test-match-briefing.js && bare test-onchain-proof.js"
  },
  "keywords": [
    "football",
    "offline",
    "p2p",
    "qvac",
    "pears",
    "wdk"
  ],
  "license": "MIT",
  "dependencies": {
