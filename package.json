    "@tetherto/wdk-wallet-evm": "^1.0.0-beta.15",
    "b4a": "^1.6.0",
    "bare-fs": "^4.7.3",
    "bare-path": "^3.0.1",
    "bare-process": "^1.0.0",
    "bare-readline": "^1.3.1",
    "bare-url": "^2.4.5",
    "hypercore-crypto": "^3.0.0",
    "hyperswarm": "^4.0.0",
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4"
  },
